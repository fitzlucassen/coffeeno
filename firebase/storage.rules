rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Shared constraints for user-uploaded images.
    function isImageUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Users can upload to their own directory
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid
                   && isImageUnder5MB();
    }

    // Roaster profile photos — only the user who claimed the roaster
    // (claimedBy field on the Firestore doc) can upload. Reads are public
    // since roaster profiles are public.
    match /roasters/{roasterId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && firestore.get(
                        /databases/(default)/documents/roasters/$(roasterId)
                      ).data.claimedBy == request.auth.uid
                   && isImageUnder5MB();
    }

    // Farm profile photos — same ownership model as roasters.
    match /farms/{farmId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && firestore.get(
                        /databases/(default)/documents/farms/$(farmId)
                      ).data.claimedBy == request.auth.uid
                   && isImageUnder5MB();
    }
  }
}
