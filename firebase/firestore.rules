rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          // New schema: roles is a list.
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles is list &&
            'admin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles)
          ||
          // Legacy schema fallback: single role string.
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
    }

    // ── Users ──
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);

      // Followers subcollection
      match /followers/{followerId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.auth.uid == followerId;
        allow delete: if isAuthenticated() && request.auth.uid == followerId;
      }

      // Following subcollection
      match /following/{targetId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // Blocks the user has initiated. Only the owner reads/writes.
      match /blocked/{targetId} {
        allow read, write: if isOwner(uid);
      }

      // Mirror record written by someone else who blocked this user. The
      // target (uid) may read to learn who blocked them (used for filtering);
      // only the blocker (targetId in this path) may write the mirror.
      match /blocked_by/{blockerId} {
        allow read: if isOwner(uid);
        allow create, delete: if isAuthenticated()
          && request.auth.uid == blockerId;
      }
    }

    // ── Coffees ──
    match /coffees/{coffeeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // ── Tastings ──
    match /tastings/{tastingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Likes subcollection
      match /likes/{uid} {
        allow read: if isAuthenticated();
        allow create: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
        // Delete permissions:
        //   - the comment's author (their own comment), OR
        //   - the owner of the tasting the comment is attached to
        //     (so users can moderate their own posts), OR
        //   - an admin.
        allow delete: if isAuthenticated() && (
          resource.data.authorId == request.auth.uid
          || get(/databases/$(database)/documents/tastings/$(tastingId)).data.userId == request.auth.uid
          || isAdmin()
        );
      }
    }

    // ── Feed (read-only, written by Cloud Functions) ──
    match /feed/{uid}/items/{itemId} {
      allow read: if isOwner(uid);
      allow write: if false; // Only Cloud Functions
    }

    // ── Roasters ──
    match /roasters/{roasterId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.claimedBy == request.auth.uid || isAdmin()
      );
    }

    // ── Farms ──
    match /farms/{farmId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.claimedBy == request.auth.uid || isAdmin()
      );
    }

    // ── Claims ──
    match /claims/{claimId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Leaderboard (read-only, written by Cloud Functions) ──
    match /leaderboard/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only Cloud Functions
    }

    // ── Roaster posts ──
    // Any authenticated user can read posts (they appear in the consumer
    // feed for users who've engaged with the roaster's coffees). Only the
    // original author can create, update, or delete a post. Admins can also
    // remove posts if moderation is ever needed.
    match /roaster_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.authorUid == request.auth.uid
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.roasterId == resource.data.roasterId;
      allow delete: if isAuthenticated()
        && (resource.data.authorUid == request.auth.uid || isAdmin());
    }
  }
}
